# Copy to .env (git-ignored) and fill in. Read by docker compose and bootstrap.sh.

# Host that runs these containers. Clients point DNS and SMB at this address.
HOST_IP=192.168.1.10

# Top-level domain everything hangs off of. Used in Caddy labels and bootstrap.sh.
LAB_DOMAIN=lab

# ONE shared login for the services that require one: MinIO (s3.lab API + console) and the
# Mattermost admin (chat.lab, full-lab profile) use LAB_USER as-is. Two consoles have FIXED
# usernames and take only the shared password:
#   - Technitium's DNS console admin is ALWAYS named "admin" (admin / LAB_PASSWORD).
#   - GitLab's admin is ALWAYS named "root" (root / LAB_PASSWORD, seeded on first boot).
# Password is shared everywhere; must be >= 8 chars (MinIO's minimum). Avoid ' and URL
# characters (@ / : ? #) in it -- it is spliced into GitLab's omnibus config and the
# Mattermost + Sourcebot postgres connection strings. bootstrap.sh also registers the
# Sourcebot owner as ${LAB_USER}@search.${LAB_DOMAIN} / LAB_PASSWORD.
LAB_USER=labadmin
LAB_PASSWORD=change-me-lab

# step-ca internal CA. Encrypts the CA keys at rest (not a login); applied on first boot
# and then persisted in volumes/stepca.
STEPCA_NAME="lab CA"
STEPCA_PASSWORD=change-me-stepca

# Vaultwarden (vault.lab). OPTIONAL: set this to enable the /admin panel (manage users,
# disable signups, global settings). Leave empty to keep the admin panel off. Generate a
# token with:  openssl rand -base64 48
VAULTWARDEN_ADMIN_TOKEN=

# ConvertX (convert.lab). Signs the session cookie; keep it stable across restarts (an empty
# value regenerates each boot and drops sessions). Open/no-login on the LAN regardless. Generate:
#   openssl rand -hex 32
CONVERTX_JWT_SECRET=change-me-convertx

# Sourcebot (search.lab). Two independent secrets, both required -- the container refuses to
# start without them. AUTH_SECRET signs session cookies; ENCRYPTION_KEY encrypts secrets at
# rest in its database. Keep both stable across restarts (changing AUTH_SECRET drops every
# session; changing ENCRYPTION_KEY orphans anything already encrypted). Generate with:
#   openssl rand -base64 33     # SOURCEBOT_AUTH_SECRET
#   openssl rand -base64 24     # SOURCEBOT_ENCRYPTION_KEY
SOURCEBOT_AUTH_SECRET=change-me-sourcebot-auth
SOURCEBOT_ENCRYPTION_KEY=change-me-sourcebot-enc

# NTP (chrony). Upstream time source(s) to discipline THIS host's clock when it has
# internet; fully offline they're unreachable and chrony just serves the host clock to the
# LAN as stratum 10. Space- or comma-separated.
NTP_SERVERS=pool.ntp.org

# DHCP (OPT-IN). Only consumed when you start the stack with `--profile dhcp`. Run a DHCP
# server here ONLY if this host is the LAN's sole DHCP authority -- two on one segment
# conflict. dnsmasq hands clients DNS=HOST_IP (-> Technitium) and NTP=HOST_IP (-> chrony)
# so they resolve *.lab and sync time with no per-client setup. Match these to your LAN.
DHCP_INTERFACE=eth0              # the host's LAN NIC (find it with `ip -br link`); DHCP binds here only
DHCP_RANGE_START=192.168.1.100   # first address to hand out (keep clear of static IPs)
DHCP_RANGE_END=192.168.1.200     # last address to hand out
DHCP_NETMASK=255.255.255.0
DHCP_GATEWAY=192.168.1.1         # the LAN's real gateway/router
DHCP_LEASE=12h
