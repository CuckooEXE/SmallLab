# lab backup config -- copy to /etc/lab-backup/config.env (or set these in the env).
# Plain shell: KEY=value, no spaces around '='.

# What to back up: the stack's data tree. This stack bind-mounts every service's
# state under <repo>/volumes (it does NOT use docker named volumes), so point SRC at
# that directory inside the repo checkout on the docker host. Local path, or
# user@host:/path to pull over ssh.  (<repo> = wherever you cloned it; /opt/lab here.)
SRC=root@dockerhost.lab:/opt/lab/volumes

# Where snapshots are stored. A LOCAL path on the machine running this script --
# the backup server's disk, or a mounted NAS. Each backup is a dated subdir here.
DEST=/backups/lab

# ssh command used when SRC is remote (key + sane defaults). Ignored if SRC is local.
SSH_RSH="ssh -i /root/.ssh/lab-backup -o BatchMode=yes -o ConnectTimeout=15 -o StrictHostKeyChecking=yes"

# Default destination for `lab-restore.sh restore <snap>` when neither --target nor
# --to is given: the live volumes/ dir to lay a snapshot back into. Same path as SRC's
# directory part, on whatever host you run the restore on. Override per-run with --target.
RESTORE_TARGET=/opt/lab/volumes

# Guaranteed-consistent copy of the live databases: briefly `docker pause` the lab
# containers during the rsync (a cgroup FREEZE -- not a stop/restart; the stack
# stays up). 1=pause, 0=hot copy. Default 0 to honor "no downtime"; flip to 1 if you
# care about a torn copy of filebrowser/step-ca's embedded DB under write.
PAUSE_CONTAINERS=0
COMPOSE_PROJECT=lab        # which project's containers to pause (only if PAUSE=1)

# Retention is the exact interval curve, defined in lab-backup.sh (KEEP_AGES).
# Backups older than 3 months are deleted automatically.
