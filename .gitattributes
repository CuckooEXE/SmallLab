# Normalize all text files to LF in the repo and on checkout.
# Prevents CRLF from ever sneaking in (no dos2unix needed).
* text=auto eol=lf

# Scripts and config that will hard-break with CRLF — force LF explicitly.
*.sh        text eol=lf
*.py        text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.json      text eol=lf
*.conf      text eol=lf
*.md        text eol=lf
*.service   text eol=lf
*.timer     text eol=lf
*.example   text eol=lf
Dockerfile  text eol=lf
.env*       text eol=lf
.gitignore  text eol=lf

# Binary — never touch line endings.
*.png       binary
*.svg       text eol=lf
